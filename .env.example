# Server-only credentials. Never prefix these with VITE_ or expose them in client code.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
CAL_API_KEY=

# Referral campaign. The service-role key is server-only and must never use a VITE_ prefix.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
REFERRAL_HASH_SALT=

# Public Supabase values used only for passwordless dashboard sign-in.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional model and deployment metadata.
OPENAI_MODEL=gpt-5.4-mini
OPENROUTER_MODEL=openai/gpt-5.4-mini
PUBLIC_SITE_URL=https://henryfadeni.vercel.app

# Optional: enable estimated USD cost in live evaluation reports.
# Use the current rates for the model selected above, expressed per 1M tokens.
EVAL_INPUT_COST_PER_MILLION=
EVAL_OUTPUT_COST_PER_MILLION=
